SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=
SUPABASE_DB_PASSWORD=
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432

STOCKFISH_PATH=

# Ile lat danych źródłowych trzymamy w bazie
SOURCE_GAMES_RETENTION_YEARS=5

# O ile miesięcy cofamy się przy kolejnym syncu
FETCH_LOOKBACK_MONTHS=1

# true = nie zapisujemy raw_json, tylko same potrzebne pola
DISABLE_RAW_JSON_STORAGE=true

ENGINE_TIME_LIMIT=0.2
ENGINE_TOP_MOVES=3
