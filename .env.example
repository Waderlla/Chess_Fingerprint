SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=
SUPABASE_DB_PASSWORD=
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432

# Maksymalna liczba partii na gracza trzymana w bazie
MAX_GAMES_PER_PLAYER=500

# O ile miesięcy cofamy się przy kolejnym syncu
FETCH_LOOKBACK_MONTHS=1

# true = nie zapisujemy raw_json, tylko same potrzebne pola
DISABLE_RAW_JSON_STORAGE=true
